:root {
    --bg-color: #0f172a;
    --card-bg: rgba(30, 41, 59, 0.7);
    --text-main: #f8fafc;
    --text-muted: #94a3b8;
    --accent-1: #8b5cf6; /* Violet */
    --accent-2: #ec4899; /* Pink */
    --accent-3: #06b6d4; /* Cyan */
    --glass-border: rgba(255, 255, 255, 0.1);
}

* { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }

body {
    background-color: var(--bg-color);
    color: var(--text-main);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
}

/* Background Blobs for Color */
.blob {
    position: fixed;
    border-radius: 50%;
    filter: blur(80px);
    z-index: -1;
    opacity: 0.6;
}
.blob-1 { top: -10%; left: -10%; width: 500px; height: 500px; background: var(--accent-1); }
.blob-2 { bottom: -10%; right: -10%; width: 400px; height: 400px; background: var(--accent-2); }

.container {
    max-width: 1100px;
    margin: 40px auto;
    padding: 20px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto auto auto;
    gap: 20px;
}

/* Widget Base Style (Glassmorphism) */
.widget {
    background: var(--card-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    padding: 25px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.widget:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    border-color: rgba(255,255,255,0.2);
}

/* --- Specific Widgets Layout --- */

/* Profile: Top Left, spans 2 cols */
.profile-widget {
    grid-column: span 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.profile-img-container {
    position: relative;
    margin-bottom: 15px;
}

.profile-pic {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    border: 3px solid var(--accent-3);
    object-fit: cover;
}

.status-indicator {
    position: absolute;
    bottom: 5px;
    right: 5px;
    width: 15px;
    height: 15px;
    background: #22c55e;
    border-radius: 50%;
    border: 2px solid var(--bg-color);
}

.role { color: var(--accent-3); font-weight: 600; margin-bottom: 15px; }

.social-links { display: flex; gap: 15px; }
.social-btn {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    display: flex; align-items: center; justify-content: center;
    color: white; text-decoration: none;
    transition: 0.3s;
}
.social-btn:hover { background: var(--accent-1); transform: scale(1.1); }

/* Education: Top Right, spans 1 col */
.education-widget { grid-column: span 1; }
.cgpa-badge {
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    padding: 8px 15px;
    border-radius: 12px;
    display: inline-block;
    margin: 10px 0;
    font-weight: bold;
}
.cgpa-badge .label { font-size: 0.7rem; opacity: 0.9; display: block; }
.cgpa-badge .value { font-size: 1.2rem; }

/* Skills: Top Right corner, spans 1 col */
.skills-widget { grid-column: span 1; }
.skills-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 15px; }
.skill-item {
    background: rgba(255,255,255,0.05);
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 0.85rem;
    border: 1px solid rgba(255,255,255,0.1);
}

/* Projects: Middle, spans full width or large area */
.projects-widget { grid-column: span 3; }
.main-project {
    background: rgba(0,0,0,0.2);
    border-radius: 16px;
    padding: 20px;
    margin-top: 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    overflow: hidden;
    position: relative;
}
.project-visual {
    width: 100px; height: 100px;
    border-radius: 50%;
    background: linear-gradient(45deg, var(--accent-3), var(--accent-1));
    filter: blur(20px);
    opacity: 0.5;
}
.tag { background: var(--accent-2); font-size: 0.7rem; padding: 2px 8px; border-radius: 4px; text-transform: uppercase; }
.project-tech span { color: var(--text-muted); font-size: 0.8rem; margin-right: 10px; }
.btn-view { color: var(--accent-3); text-decoration: none; font-weight: 600; margin-top: 10px; display: inline-block; }

.project-list { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 15px; }
.mini-project { background: rgba(255,255,255,0.03); padding: 15px; border-radius: 12px; border-left: 3px solid var(--accent-1); }

/* Certificates: Bottom Right, spans 1 col */
.certs-widget { grid-column: span 1; }
.cert-list { list-style: none; margin-top: 15px; }
.cert-list li { display: flex; align-items: center; gap: 10px; margin-bottom: 15px; }
.cert-list i { font-size: 1.2rem; }
.cert-list .gold { color: #fbbf24; }
.cert-list .blue { color: #60a5fa; }
.cert-list .purple { color: #c084fc; }
.cert-list strong { display: block; font-size: 0.9rem; }
.cert-list span { font-size: 0.75rem; color: var(--text-muted); }

/* General Typography */
h1 { font-size: 2rem; margin-bottom: 5px; }
h2 { font-size: 1.2rem; margin-bottom: 15px; color: var(--text-main); display: flex; align-items: center; gap: 10px; }
h3 { font-size: 1.1rem; margin-bottom: 5px; }
p { color: var(--text-muted); font-size: 0.9rem; line-height: 1.5; }
.widget-header i { color: var(--accent-3); }

footer { text-align: center; padding: 40px; color: var(--text-muted); font-size: 0.8rem; }

/* Mobile Responsiveness */
@media (max-width: 768px) {
    .container { grid-template-columns: 1fr; }
    .profile-widget, .education-widget, .skills-widget, .projects-widget, .certs-widget { grid-column: span 1; }
    .main-project { flex-direction: column; text-align: left; align-items: flex-start; }
    .project-visual { margin-top: 15px; }
}
